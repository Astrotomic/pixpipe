{
    "name": "astrotomic/pixpipe",
    "description": "On-the-fly image manipulation and delivery for Laravel using Intervention Image and Glide (signed URLs, caching, Flysystem).",
    "license": "MIT",
    "keywords": [
        "laravel",
        "image",
        "images",
        "image-manipulation",
        "image-processing",
        "intervention-image",
        "glide",
        "signed-urls",
        "flysystem",
        "http"
    ],
    "authors": [
        {
            "name": "Tom Herrmann",
            "email": "gummibeer@astrotomic.info",
            "homepage": "https://gummibeer.de",
            "role": "Developer"
        }
    ],
    "homepage": "https://astrotomic.info",
    "require": {
        "php": "^8.2",
        "illuminate/container": "^12.0",
        "illuminate/contracts": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/support": "^12.0",
        "intervention/image": "^3.11",
        "intervention/image-laravel": "^1.5",
        "league/flysystem": "^3.0",
        "league/glide": "^3.0",
        "nesbot/carbon": "^3.8.4",
        "symfony/http-foundation": "^7.0",
        "symfony/http-kernel": "^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Astrotomic\\Pixpipe\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Astrotomic\\Pixpipe\\PixpipeServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@composer normalize --ansi --no-interaction",
            "@composer thanks --ansi --no-interaction --quiet"
        ],
        "fix": "@php vendor/bin/pint",
        "normalize": "echo 'composer global require ergebnis/composer-normalize'",
        "thanks": "echo 'composer global require symfony/thanks'"
    }
}
